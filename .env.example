# CodeBuddy Development Environment Configuration
# Copy this file to .env and fill in the actual values

# MongoDB Database Name
APPLICATION_MONGO_DB=codebuddy

# Security - Generate with: openssl rand -hex 32
APPLICATION_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# NextAuth Secret - Must match between frontend and backend
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Optional: Add any API keys needed for AI agents
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_API_KEY=your-google-api-key