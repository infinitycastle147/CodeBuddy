# NextAuth Configuration
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Database
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/CodeBuddy"
MONGODB_LOCAL_URI="mongodb://localhost:27017/CodeBuddy"

# GitHub OAuth Provider (optional)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Email Provider (optional - configure only if needed)
EMAIL_SERVER="smtp://username:password@smtp.example.com:587"
EMAIL_FROM="noreply@example.com"