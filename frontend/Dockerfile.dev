# Development Dockerfile for CodeBuddy Frontend
# Optimized for fast development with hot reload and debugging

FROM node:20-alpine AS base

# Install dependencies only when needed
FROM base AS deps
RUN apk add --no-cache libc6-compat curl

WORKDIR /app

# Copy package files and dockerignore
COPY package.json package-lock.json* .dockerignore* ./

# Install dependencies (removed legacy flag - fix deps instead)
RUN npm ci

# Development image, copy all the files and run next dev
FROM base AS dev

# Add metadata labels
LABEL maintainer="codebuddy-team" \
      version="1.0" \
      description="CodeBuddy Frontend Development Environment" \
      environment="development"

WORKDIR /app

# Create non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy source code
COPY . .

# Set proper ownership and create necessary directories
RUN chown -R nextjs:nodejs /app && \
    mkdir -p /app/.next /app/.next/cache && \
    chown -R nextjs:nodejs /app/.next

# Switch to non-root user
USER nextjs

# Environment variables
EXPOSE 3000
ENV PORT=3000 \
    HOSTNAME="0.0.0.0" \
    NEXT_TELEMETRY_DISABLED=0 \
    NODE_ENV=development

# Fire up the engine
CMD ["npm", "run", "dev"]