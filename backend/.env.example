# CodeBuddy Backend Environment Configuration
# Copy this file to .env and fill in the actual values

# Application Settings
APPLICATION_NAME=CodeBuddy
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8000
APPLICATION_ENVIRONMENT=production
APPLICATION_AUTO_RELOAD=false

# Uvicorn Settings
APPLICATION_UVICORN_WORKERS_COUNT=4
APPLICATION_UVICORN_TIMEOUT=120
APPLICATION_UVICORN_GRACEFUL_TIMEOUT=30
APPLICATION_UVICORN_KEEP_ALIVE=2

# CORS Settings
APPLICATION_CORS_ALLOW_ORIGINS=*
APPLICATION_CORS_ALLOW_METHODS=*
APPLICATION_CORS_ALLOW_HEADERS=*

# Database Settings
APPLICATION_MONGO_URI=mongodb://mongo:27017/
APPLICATION_MONGO_DB=CodeBuddy
APPLICATION_MONGO_COLLECTION=codebuddy

# MongoDB Authentication (for production)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your-secure-password-here

# Redis Settings
APPLICATION_REDIS_URL=redis://redis:6379/0

# Security Settings
APPLICATION_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# Langfuse Settings (AI Observability)
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# Additional Environment Variables (add as needed)
# OPENAI_API_KEY=your-openai-dependencies-key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json